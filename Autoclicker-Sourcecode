            self.repeat_sub.pack(fill="x", pady=(2, 6))
        else:
            self.repeat_sub.pack_forget()

    # ══════════════════ CAPTURE ══════════════════

    def start_key_capture(self):
        if self.current_hotkey:
            try: keyboard.remove_hotkey(self.current_hotkey)
            except: pass
        self.status_label.config(text="WAITING…", fg=YELLOW)
        self.status_dot.itemconfig(self._dot_oval, fill=YELLOW)
        threading.Thread(target=self._capture_key_thread, daemon=True).start()

    def _capture_key_thread(self):
        try:
            event = keyboard.read_event(suppress=True)
            if event.event_type == keyboard.KEY_DOWN:
                key = event.name
                vk  = event.scan_code
                display = key.upper() if len(key) == 1 else key.title()
                self.target_key_var.set(key)
                self.target_vk = vk
                self.root.after(0, lambda d=display: self.key_display.config(text=d))
        except: pass
        self.root.after(0, self._restore_stopped)
        self.root.after(0, self.apply_hotkey)

    def start_hotkey_capture(self):
        if self.current_hotkey:
            try: keyboard.remove_hotkey(self.current_hotkey)
            except: pass
        self.hotkey_display.config(text="?", fg=YELLOW)
        self.status_label.config(text="WAITING…", fg=YELLOW)
        self.status_dot.itemconfig(self._dot_oval, fill=YELLOW)
        threading.Thread(target=self._capture_hotkey_thread, daemon=True).start()

    def _capture_hotkey_thread(self):
        try:
            event = keyboard.read_event(suppress=True)
            if event.event_type == keyboard.KEY_DOWN:
                key = event.name
                self.toggle_hotkey_var.set(key)
                display = key.upper() if len(key) == 1 else key.title()
                self.root.after(0, lambda d=display: self.hotkey_display.config(text=d, fg=ACCENT2))
        except: pass
        self.root.after(0, self._restore_stopped)
        self.root.after(0, self.apply_hotkey)

    # ══════════════════ HOTKEY ══════════════════

    def apply_hotkey(self):
        if self.current_hotkey:
            try: keyboard.remove_hotkey(self.current_hotkey)
            except: pass
        hot = self.toggle_hotkey_var.get().strip()
        if hot:
            try:
                self.current_hotkey = keyboard.add_hotkey(hot, self.toggle_clicker, suppress=True)
            except:
                self.status_label.config(text="INVALID HOTKEY", fg=RED)

    # ══════════════════ TOGGLE ══════════════════

    def toggle_clicker(self):
        self.running = not self.running
        if self.running:
            self.root.after(0, self._set_running_ui)
            if self.hold_var.get():
                self._do_press()
                self.held = True
            else:
                if not self.click_thread or not self.click_thread.is_alive():
                    self.count_at_start = self.count
                    self.click_thread = threading.Thread(
                        target=self._spam_loop, daemon=True)
                    self.click_thread.start()
        else:
            self.root.after(0, self._restore_stopped)
            if self.held:
                self._do_release()
                self.held = False

    def _set_running_ui(self):
        self.status_label.config(text="RUNNING", fg=ACCENT)
        self.status_dot.itemconfig(self._dot_oval, fill=ACCENT)

    def _restore_stopped(self):
        self.status_label.config(text="STOPPED", fg=RED)
        self.status_dot.itemconfig(self._dot_oval, fill=RED)

    # ══════════════════ PRESS / RELEASE ══════════════════

    def _do_press(self):
        if self.mode_var.get() == "Keyboard":
            key = self.target_key_var.get().strip()
            if key:
                try: keyboard.press(key)
                except: pass
        else:
            try: mouse.press(self.mouse_btn_var.get())
            except: pass

    def _do_release(self):
        if self.mode_var.get() == "Keyboard":
            key = self.target_key_var.get().strip()
            if key:
                try: keyboard.release(key)
                except: pass
        else:
            try: mouse.release(self.mouse_btn_var.get())
            except: pass

    # ══════════════════ SPAM LOOP (OPTIMISED) ══════════════════

    def _spam_loop(self):
        import random
        is_keyboard = (self.mode_var.get() == "Keyboard")
        key         = self.target_key_var.get().strip()
        btn         = self.mouse_btn_var.get()

        # Pre-read toggles once per loop start (avoids tkinter calls inside loop)
        max_speed   = self.max_speed_var.get()
        use_jitter  = self.jitter_var.get()
        jitter_pct  = self.jitter_pct_var.get() / 100.0
        has_limit   = self.repeat_limit_var.get()
        limit       = self.repeat_count_var.get() if has_limit else 0
        interval    = self.interval_var.get() / 1000.0

        loop_count  = 0

        while self.running:
            # ── CLICK ──
            try:
                if is_keyboard:
                    keyboard.press_and_release(key)
                else:
                    fast_mouse_click(btn)
            except:
                pass

            # ── COUNT ──
            loop_count += 1
            self.count += 1
            ts = time.perf_counter()
            self._cps_window.append(ts)

            # trim window older than 1s
            cutoff = ts - 1.0
            while self._cps_window and self._cps_window[0] < cutoff:
                self._cps_window.pop(0)

            # Check repeat limit
            if has_limit and loop_count >= limit:
                self.running = False
                self.root.after(0, self._restore_stopped)
                break

            # ── SLEEP ──
            if max_speed:
                # Ultra-fast: yield once per click to avoid 100% CPU lockup
                time.sleep(0.0005)
            else:
                delay = interval
                if use_jitter:
                    delay *= (1.0 + random.uniform(-jitter_pct, jitter_pct))
                    delay = max(0.001, delay)
                hr_sleep(delay)

    # ══════════════════ CPS UPDATER ══════════════════

    def _cps_updater(self):
        # Calculate CPS from rolling window
        now = time.perf_counter()
        cutoff = now - 1.0
        while self._cps_window and self._cps_window[0] < cutoff:
            self._cps_window.pop(0)
        cps = len(self._cps_window)
        self.cps_label.config(text=f"{cps}")
        self.count_label.config(text=f"{self.count:,}")
        self.root.after(100, self._cps_updater)

    # ══════════════════ MISC ══════════════════

    def test_action(self):
        try:
            if self.mode_var.get() == "Keyboard":
                keyboard.press_and_release(self.target_key_var.get().strip())
            else:
                fast_mouse_click(self.mouse_btn_var.get())
        except: pass
        self.count += 1

    def reset_counter(self):
        self.count = 0
        self._cps_window.clear()
        self.count_label.config(text="0")
        self.cps_label.config(text="0")

    def on_close(self):
        self.running = False
        if self.held:
            self._do_release()
        if self.current_hotkey:
            try: keyboard.remove_hotkey(self.current_hotkey)
            except: pass
        self.root.destroy()


