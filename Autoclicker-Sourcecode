# ─────────────────────────────────────────────
#  ULTRA-FAST INPUT via ctypes (no overhead)
# ─────────────────────────────────────────────
MOUSEEVENTF_LEFTDOWN   = 0x0002
MOUSEEVENTF_LEFTUP     = 0x0004
MOUSEEVENTF_RIGHTDOWN  = 0x0008
MOUSEEVENTF_RIGHTUP    = 0x0010
MOUSEEVENTF_MIDDLEDOWN = 0x0020
MOUSEEVENTF_MIDDLEUP   = 0x0040

INPUT_KEYBOARD = 1
KEYEVENTF_KEYUP = 0x0002
KEYEVENTF_SCANCODE = 0x0008

class KEYBDINPUT(ctypes.Structure):
    _fields_ = [
        ("wVk",         ctypes.c_ushort),
        ("wScan",       ctypes.c_ushort),
        ("dwFlags",     ctypes.c_ulong),
        ("time",        ctypes.c_ulong),
        ("dwExtraInfo", ctypes.POINTER(ctypes.c_ulong)),
    ]

class _INPUT_UNION(ctypes.Union):
    _fields_ = [("ki", KEYBDINPUT), ("_pad", ctypes.c_byte * 24)]

class INPUT(ctypes.Structure):
    _fields_ = [("type", ctypes.c_ulong), ("_input", _INPUT_UNION)]

def fast_mouse_click(button="left"):
    if button == "left":
        down, up = MOUSEEVENTF_LEFTDOWN, MOUSEEVENTF_LEFTUP
    elif button == "right":
        down, up = MOUSEEVENTF_RIGHTDOWN, MOUSEEVENTF_RIGHTUP
    else:
        down, up = MOUSEEVENTF_MIDDLEDOWN, MOUSEEVENTF_MIDDLEUP
    ctypes.windll.user32.mouse_event(down, 0, 0, 0, 0)
    ctypes.windll.user32.mouse_event(up,   0, 0, 0, 0)

def fast_key_click(vk_code):
    extra = ctypes.c_ulong(0)
    ii = _INPUT_UNION()
    ii.ki = KEYBDINPUT(vk_code, 0, 0, 0, ctypes.pointer(extra))
    inp = INPUT(INPUT_KEYBOARD, ii)
    ctypes.windll.user32.SendInput(1, ctypes.byref(inp), ctypes.sizeof(inp))
    ii2 = _INPUT_UNION()
    ii2.ki = KEYBDINPUT(vk_code, 0, KEYEVENTF_KEYUP, 0, ctypes.pointer(extra))
    inp2 = INPUT(INPUT_KEYBOARD, ii2)
    ctypes.windll.user32.SendInput(1, ctypes.byref(inp2), ctypes.sizeof(inp2))

# High-resolution sleep using Windows timer
def hr_sleep(seconds):
    """High-resolution sleep using Windows multimedia timer."""
    if seconds <= 0:
        return
    deadline = time.perf_counter() + seconds
    while time.perf_counter() < deadline:
        remaining = deadline - time.perf_counter()
        if remaining > 0.002:
            time.sleep(remaining * 0.5)
        # spin for last 2ms for accuracy

