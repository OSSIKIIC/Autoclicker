                 fg=TEXT_DIM, bg=BG if parent.cget("bg") == BG else PANEL,
                 anchor="w").pack(fill="x")

    def _mode_btn(self, parent, label, value):
        btn = tk.Label(parent, text=label, font=FONT_LABEL,
                       bg=BORDER, fg=TEXT, padx=16, pady=8, cursor="hand2")
        btn.pack(side="left", padx=(0, 6))
        btn.bind("<Button-1>", lambda e: self._set_mode(value))
        return btn

    def _update_mode_btns(self):
        mode = self.mode_var.get()
        self.mode_kb_btn.config(bg=ACCENT,  fg=BG)   if mode == "Keyboard" else \
        self.mode_kb_btn.config(bg=BORDER,  fg=TEXT)
        self.mode_ms_btn.config(bg=ACCENT,  fg=BG)   if mode == "Mouse" else \
        self.mode_ms_btn.config(bg=BORDER,  fg=TEXT)

    def _set_mode(self, value):
        self.mode_var.set(value)
        self._update_mode_btns()
        if value == "Keyboard":
            self.mouse_frame.pack_forget()
            self.key_frame.pack(fill="x", pady=(0, 12))
        else:
            self.key_frame.pack_forget()
            self.mouse_frame.pack(fill="x", pady=(0, 12))

    def _pick_mouse_btn(self, value):
        self.mouse_btn_var.set(value)
        self._update_mouse_btns()

    def _update_mouse_btns(self):
        sel = self.mouse_btn_var.get()
        for btn in ["left", "right", "middle"]:
            w = getattr(self, f"_mbtn_{btn}")
            w.config(bg=ACCENT2 if btn == sel else BORDER,
                     fg=BG     if btn == sel else TEXT)

    def _toggle_row(self, parent, label, tip, var, command, row):
        fr = tk.Frame(parent, bg=BG)
        fr.grid(row=row, column=0, sticky="ew", pady=4)

        sw = ToggleSwitch(fr, var, command=command)
        sw.pack(side="left", padx=(0, 10))

        lbl = tk.Label(fr, text=label, font=FONT_LABEL, fg=TEXT, bg=BG, anchor="w")
        lbl.pack(side="left")
        Tooltip(lbl, tip)

    def _on_maxspeed(self):
        pass  # just reads the var in spam_loop

